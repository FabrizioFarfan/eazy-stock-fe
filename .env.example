# Backend API URL
# In development the Vite proxy rewrites /api → http://localhost:8080
# so you can leave this as /api (default).
# For production set the full URL: https://api.yourdomain.com/api
VITE_API_URL=/api

# WebSocket base URL (derived from VITE_API_URL in wsClient.js — only needed for reference)
# In development the Vite proxy rewrites /ws → ws://localhost:8080/ws (ws: true in vite.config.js)
# For production set to the bare origin: https://api.yourdomain.com
VITE_WS_URL=http://localhost:8080
