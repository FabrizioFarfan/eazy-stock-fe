# ── Development ──────────────────────────────────────────────────────────────
# Copy this file to .env.development and adjust as needed.
# The Vite dev proxy also rewrites /api and /ws so you can use relative paths,
# but explicit URLs work fine too (CORS allows localhost:5173).

VITE_API_URL=http://localhost:9393/api
VITE_WS_URL=http://localhost:9393

# ── Production ────────────────────────────────────────────────────────────────
# .env.production (committed) already contains these values:
#
# VITE_API_URL=https://api.eazy-stock.com/api
# VITE_WS_URL=https://api.eazy-stock.com
